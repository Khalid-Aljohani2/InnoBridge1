# Laravel API root (no trailing slash). Used by axios as baseURL.
# Local dev:
#   VITE_API_BASE_URL=http://127.0.0.1:8000
# Netlify production (required — Vite bakes this in at build time):
# Laravel app root ONLY — no trailing slash, no /api suffix (code calls `/api/...`).
#   VITE_API_BASE_URL=https://your-app.onrender.com
VITE_API_BASE_URL=https://innobridge-backend-ts7m.onrender.com

# Set to true only for Sanctum SPA cookie/CSRF across different domains (stricter CORS on Laravel).
# Leave unset or false when using Bearer tokens only (typical for this SPA → API).
# VITE_API_WITH_CREDENTIALS=true

# Supabase browser client (anon key only; never commit service-role keys).
# Optional until you enable Supabase Auth or direct-from-browser reads guarded by RLS.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
