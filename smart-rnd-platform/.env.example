APP_NAME=InnoBridge
VITE_APP_NAME=InnoBridge

# ═══════════════════════════════════════════════════════════════════════════
# وضع «كل شيء على السحابة» → راجع أيضاً docs/CLOUD_FULL_STACK.md
# إنتاج: APP_ENV=production | APP_DEBUG=false | APP_URL=https://your-domain
# إلغ SQLite: ضع DB_CONNECTION=pgsql + DB_URL (pooler Supabase :6543) ثم migrate --force
# ═══════════════════════════════════════════════════════════════════════════

APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Must match the host and port you use in the browser (e.g. http://127.0.0.1:8002).
# After changing the port, run: php artisan config:clear
APP_URL=http://localhost

# ── Decoupled SPA (Vite frontend) + CORS ───────────────────────────────────────
# عنوان الواجهة التي تتصل بـ API؛ يُستخدم لبناء قائمة CORS الافتراضية.
FRONTEND_URL=http://localhost:5173
# قائمة مفصولة بفواصل لجميع أصول المسموح بها (بدون شرطة مائلة أخيرة موصى بها).
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# أنماط بديلة (اختياري): CORS_ALLOWED_ORIGINS_PATTERNS=
# تفعيل ملفات تعريف الارتباط / جلسات المتصفح بين أصلين (true عند استخدام Sanctum SPA cookies).
CORS_SUPPORTS_CREDENTIALS=true
# CORS_MAX_AGE=0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# إن رأيت المستخدمين في Supabase لكن تسجيل الدخول يفشل («بيانات اعتماد غير صحيحة»):
# 1) تأكد أن Laravel يتصل بـ Postgres وليس SQLite: عيِّن DB_CONNECTION=pgsql و DB_* أو DB_URL الصحيحة.
# 2) نفِّذ: php artisan config:clear && php artisan cache:clear
# 3) تحقق من الاتصال: php artisan app:verify-db (أو php artisan db:show)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite
#
# Faster local browsing (recommended when Supabase/pg round-trips are slow): SQLite file + CACHE_STORE=file.
# DATABASE_URL omitted — use Postgres only for staging/production or when you need parity.

# Slow cross-region Postgres? Prefer SQLite locally, or expect higher latency:

# --- PostgreSQL (Supabase) — استخدم أحد الأسلوبين: DB_URL أو المتغيرات المنفصلة ---
#
# أ) سلسلة اتصال واحدة (موصى به عند نسخها من Supabase → Connection string):
#     DB_CONNECTION=pgsql
#     DB_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require"
#     DB_SSLMODE=require
#
#     • منفذ 6543 = Session/Transaction pooler (مناسب لخواديم PHP / Laravel).
#     • منفذ 5432 = اتصال مباشر (أحياناً للهجرات الثقيلة فقط).
#
# ب) متغيرات منفصلة (إن لم تستخدم DB_URL):
#     DB_CONNECTION=pgsql
#     DB_HOST=aws-0-xx.pooler.supabase.com
#     DB_PORT=6543
#     DB_DATABASE=postgres
#     DB_USERNAME=postgres.xxxxxxxxxxxxxxxx
#     DB_PASSWORD=
#     DB_SSLMODE=require
#
# ملاحظات أمنية:
#     — لا ترفع .env إلى Git. انسخ من .env.example فقط على السيرفر.
#     — مفاتيح Supabase «anon / service_role» لـ JS/Edge وليست بديلاً عن DB_* لـ Eloquent.
#
# --- بدائل قديمة (MySQL) ---
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Web only: when true and APP_ENV is local|testing, login works with email (+ role) without password. Never in production.
AUTH_PASSWORDLESS_LOGIN=false

# Optional: comma-separated hosts for SPA first-party cookies (must include frontend host:port).
# أضف منفذ Vite مثلاً: localhost:5173,127.0.0.1:5173
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:3000,localhost:8000,127.0.0.1,127.0.0.1:5173,127.0.0.1:8000,::1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Hugging Face Inference API (semantic similarity / embeddings)
HUGGINGFACE_API_KEY=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
IDEA_SIMILARITY_WARN_MIN=40
IDEA_SIMILARITY_BLOCK_MIN=70
IDEA_SIMILARITY_MAX_TEXT_CHARS=8000
# false = لا تغيير عن السابق (التضمين أثناء الرفع؛ أبطأ لكن تقرير فوري كامل).
# true = الواجهة تستجيب أسرع (مقارنة نصية فقط في الطلب)، والتضمين يُكمَّل عبر ProcessProjectEmbeddingJob؛ شغّل queue worker أو لن يُحدَّث vector_embedding بعد الرفع.
ORIGINALITY_DEFER_EMBEDDING=false
